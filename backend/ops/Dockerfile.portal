FROM node:22-alpine AS build

WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci

WORKDIR /app

COPY backend ./backend
COPY web-app ./web-app
RUN ln -s /app/backend/node_modules /app/web-app/node_modules

ARG VITE_API_URL=https://api.docduty.com.pk/api
ENV VITE_API_URL=${VITE_API_URL}

RUN npm --prefix backend run build

FROM nginx:alpine

COPY backend/ops/portal.nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/backend/dist /usr/share/nginx/html
