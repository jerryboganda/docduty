# ==============================================
# DocDuty Environment Configuration
# Copy this file to .env.local and update values
# ==============================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080
START_BACKGROUND_JOBS=true
PUBLIC_API_URL=
UPLOADS_DIR=data/uploads

# JWT Authentication
# IMPORTANT: Use strong random secrets outside local development.
JWT_SECRET=docduty-dev-secret-change-in-production
JWT_REFRESH_SECRET=docduty-dev-refresh-secret-change-in-production

# PostgreSQL
DATABASE_URL=postgresql://docduty:docduty@localhost:5432/docduty
MIGRATION_DATABASE_URL=postgresql://docduty:docduty@localhost:5432/docduty
TEST_DATABASE_URL=postgresql://docduty:docduty@localhost:5432/docduty_test
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_QUERY_TIMEOUT_MS=15000
DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=15000
DATABASE_RETRY_MAX_ATTEMPTS=8
DATABASE_RETRY_BACKOFF_MS=1500
DATABASE_APPLICATION_NAME=docduty-api
SEED_REFERENCE_DATA=true
SEED_DEMO_DATA=true

# Local Docker Compose PostgreSQL bootstrap
POSTGRES_DB=docduty
POSTGRES_USER=docduty
POSTGRES_PASSWORD=docduty

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_ENABLE_REALTIME=false
VITE_SOKETI_HOST=localhost
VITE_SOKETI_PORT=6001
VITE_SOKETI_APP_KEY=app-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# AI / External Services
# ==============================================

# Gemini AI (optional - do not expose real secrets in client builds)
GEMINI_API_KEY=""
# Public app URL
APP_URL="http://localhost:3000"

# ==============================================
# Future / External Integrations (not yet active)
# ==============================================

# SMS Gateway (e.g., Twilio / local Pakistan provider)
# SMS_PROVIDER=twilio
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_FROM_NUMBER=

# Payment Gateway (e.g., JazzCash / Easypaisa / Stripe)
# PAYMENT_PROVIDER=jazzcash
# PAYMENT_MERCHANT_ID=
# PAYMENT_API_KEY=
# PAYMENT_API_SECRET=

# Email (for admin notifications)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@docduty.pk

# Cloud Storage (for document uploads)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1
