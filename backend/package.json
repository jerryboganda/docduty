{
  "name": "docduty",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts --watch",
    "server": "tsx server/index.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build --config ../web-app/vite.config.ts",
    "start": "tsx server/index.ts",
    "worker": "tsx server/worker.ts",
    "preview": "vite preview --config ../web-app/vite.config.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit -p ../web-app/tsconfig.json",
    "typecheck": "tsc --noEmit -p ../web-app/tsconfig.json",
    "test:unit": "tsx --test test/unit/index.test.ts",
    "test:integration": "tsx --test test/integration/index.test.ts",
    "test:e2e": "tsx --test test/e2e/index.test.ts",
    "inventory": "tsx scripts/generate-route-inventory.ts && tsx scripts/generate-interaction-inventory.ts",
    "audit:ui": "tsx scripts/portal-click-audit.ts",
    "audit:a11y": "tsx scripts/a11y-smoke.ts",
    "perf:load": "tsx scripts/load-test.ts",
    "db:migrate": "tsx server/database/migrate.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:import:sqlite": "tsx scripts/import-sqlite-to-postgres.ts",
    "test:all": "npm run lint && npm run build && npm run test:unit && npm run test:integration && npm run test:e2e",
    "readiness:all": "npm run inventory && npm run test:all && npm run audit:ui && npm run audit:a11y && npm run perf:load",
    "ci": "npm run readiness:all"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "framer-motion": "^12.35.1",
    "helmet": "^8.1.0",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "vite": "^6.2.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "pg-mem": "^3.0.14",
    "playwright": "^1.58.2",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
